{
  "name": "ecommerco-pos-terminal",
  "version": "1.0.0",
  "description": "Card-present POS for Dell Latitude 7400 using Electron + Stripe Terminal",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently -k \"npm run start:backend\" \"npm run start:electron\"",
    "start:backend": "node backend/server.js",
    "start:electron": "wait-on tcp:3001 && electron electron/main.js",
    "test": "node --test backend/tests/*.test.js"
  },
  "keywords": [
    "pos",
    "stripe-terminal",
    "electron",
    "card-present"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.5.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron": "^31.2.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "stripe": "^16.12.0",
    "uuid": "^10.0.0",
    "wait-on": "^7.2.0"
  }
}
